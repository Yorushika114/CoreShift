// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Event {
  id              String    @id @default(cuid())
  userId          String    @default("")
  title           String
  startAt         DateTime
  endAt           DateTime?
  reminderAt      DateTime?
  allDay          Boolean   @default(false)
  recurrence      String?
  color           String    @default("blue")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sourceText      String?
  googleEventId       String?   @unique
  googleUpdatedAt     DateTime?
  googleCalendarId    String?
  googleCalendarColor String?
  icsUid              String?   @unique
  icsSeriesUid        String?
}

model TimeBudget {
  id            String   @id @default(cuid())
  userId        String   @default("")
  label         String
  keywords      String
  targetMinutes Int
  color         String   @default("emerald")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Session {
  id                     String   @id @default(cuid())
  visitorId              String   @default("")
  googleSub              String   @default("")
  email                  String   @default("")
  accessToken            String
  refreshToken           String
  expiresAt              DateTime
  createdAt              DateTime @default(now())
  selectedCalendarIds    String   @default("[]")
  defaultWriteCalendarId String   @default("primary")
}
