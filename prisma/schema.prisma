// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Event {
  id              String    @id @default(cuid())
  userId          String    @default("")
  title           String
  startAt         DateTime
  endAt           DateTime?
  reminderAt      DateTime?
  allDay          Boolean   @default(false)
  recurrence      String?
  recurrenceEndAt DateTime?
  recurrenceCount Int?
  color           String    @default("blue")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sourceText      String?
  googleEventId       String?   @unique
  googleUpdatedAt     DateTime?
  googleCalendarId    String?
  googleCalendarColor String?
  icsUid              String?   @unique
  icsSeriesUid        String?
  exceptions      EventException[]
}

model TimeBudget {
  id            String   @id @default(cuid())
  userId        String   @default("")
  label         String
  keywords      String
  targetMinutes Int
  color         String   @default("emerald")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Session {
  id                     String   @id @default(cuid())
  visitorId              String   @default("")
  googleSub              String   @default("")
  email                  String   @default("")
  accessToken            String
  refreshToken           String
  expiresAt              DateTime
  createdAt              DateTime @default(now())
  selectedCalendarIds    String   @default("[]")
  defaultWriteCalendarId String   @default("primary")
  syncDirection          String   @default("both")
}

model EventException {
  id         String    @id @default(cuid())
  eventId    String
  event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  date       DateTime
  isDeleted  Boolean   @default(false)
  title      String?
  startAt    DateTime?
  endAt      DateTime?
  reminderAt DateTime?
  color      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([eventId, date])
}

model PendingGoogleDelete {
  id               String   @id @default(cuid())
  googleEventId    String
  googleCalendarId String?
  visitorId        String
  userId           String
  createdAt        DateTime @default(now())

  @@unique([googleEventId, userId])
}
