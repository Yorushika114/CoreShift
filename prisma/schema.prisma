// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Event {
  id         String    @id @default(cuid())
  title      String
  startAt    DateTime
  endAt      DateTime?
  reminderAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  sourceText String?
}
